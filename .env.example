# ══════════════════════════════════════════════════════════════════════════════
# .env.example — Copy this file to .env and fill in your real values
# ══════════════════════════════════════════════════════════════════════════════

# ── LiveKit Cloud ─────────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io/ → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Groq (LLM) ───────────────────────────────────────────────────────────────
# Get from: https://console.groq.com/ → API Keys
GROQ_API_KEY=gsk_your_groq_key

# ── Sarvam AI (STT + TTS) ─────────────────────────────────────────────────────
# Get from: https://app.sarvam.ai/
SARVAM_API_KEY=sk_your_sarvam_key

# ── Cal.com (Appointment Booking) ─────────────────────────────────────────────
# Get from: https://app.cal.com/settings/developer/api-keys
CAL_API_KEY=cal_live_your_key
CAL_EVENT_TYPE_ID=your_event_type_id

# ── Supabase (Database + Storage) ─────────────────────────────────────────────
# Get from: https://app.supabase.com/ → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── Supabase S3 (Call Recordings) ─────────────────────────────────────────────
# Get from: Supabase Dashboard → Storage → Settings → S3 Access → Generate key
SUPABASE_S3_ACCESS_KEY=your_s3_access_key
SUPABASE_S3_SECRET_KEY=your_s3_secret_key
SUPABASE_S3_ENDPOINT=https://your-project-id.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-northeast-2

# ── Telegram Notifications ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your Chat ID
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── SIP / VoBiz (Inbound Phone Number) ───────────────────────────────────────
# Get from: https://vobiz.ai → your SIP trunk details
# Also create an Inbound Trunk at: https://cloud.livekit.io → SIP
SIP_TRUNK_ID=ST_your_trunk_id
VOBIZ_SIP_DOMAIN=your_sip_domain.sip.vobiz.ai
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# ── Call Transfer (Human Agent Fallback) ──────────────────────────────────────
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX
